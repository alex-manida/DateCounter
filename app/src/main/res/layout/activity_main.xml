<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".MainActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/app_bar"
        app:title="Date Counter"
        app:titleCentered="true"
        app:titleTextColor="@color/text_primary" />

    <!-- First Person Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:elevation="4dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_1"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/person_1" />

            <TextView
                android:id="@+id/tv_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="First Person"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Second Person Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:elevation="4dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_2"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/person_2" />

            <TextView
                android:id="@+id/tv_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Second Person"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Heart Image -->
    <ImageView
        android:id="@+id/iv_heart"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/heart_1"
        app:layout_constraintBottom_toBottomOf="@id/cv_2"
        app:layout_constraintEnd_toStartOf="@id/cv_2"
        app:layout_constraintStart_toEndOf="@id/cv_1"
        app:layout_constraintTop_toTopOf="@id/cv_1" />

    <!-- Date Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/bt_select_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/button_bg"
        android:text="Dec 04, 2024"
        android:textColor="@color/text_primary"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="@id/cv_2"
        app:layout_constraintStart_toStartOf="@id/cv_1"
        app:layout_constraintTop_toBottomOf="@id/cv_1" />

    <!-- Date Counter Text -->
    <TextView
        android:id="@+id/tv_Date_Counter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="1500 Days"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="@id/bt_select_date"
        app:layout_constraintStart_toStartOf="@id/bt_select_date"
        app:layout_constraintTop_toBottomOf="@id/bt_select_date" />

</androidx.constraintlayout.widget.ConstraintLayout>
